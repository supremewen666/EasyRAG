# Copy this file to `.env` and fill in the values you need.

# Optional: override the repository root used for indexing and local storage.
EASYRAG_REPO_ROOT=/Users/supremewen/EasyRAG

# Optional: keep local indexes under a custom directory.
EASYRAG_DATA_DIR=/Users/supremewen/EasyRAG/.easyrag
EASYRAG_INDEX_PATH=/Users/supremewen/EasyRAG/.easyrag/rag_index.json

# OpenAI-compatible model configuration.
EASYRAG_MODEL=openai:gpt-4.1-mini
EASYRAG_MODEL_NAME=gpt-4.1-mini
EASYRAG_QUERY_MODEL_NAME=gpt-4.1-mini
EASYRAG_EMBEDDING_MODEL_NAME=qwen3-embedding
EASYRAG_RERANK_MODEL_NAME=qwen3-rerank
EASYRAG_KG_MODEL_NAME=gpt-4.1-mini

# Example DeepSeek-compatible setup:
# EASYRAG_MODEL=openai:deepseek-chat
# EASYRAG_MODEL_NAME=deepseek-chat

# Model provider credentials.
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=
EASYRAG_QUERY_BASE_URL=
EASYRAG_EMBEDDING_BASE_URL=
EASYRAG_RERANK_BASE_URL=
EASYRAG_KG_BASE_URL=
EASYRAG_KG_ENTITY_TYPES=

# Example DeepSeek-compatible base URL:
# OPENAI_BASE_URL=https://api.deepseek.com

# Optional production RAG backend bundle.
# Set `EASYRAG_STORAGE_BACKEND=postgres_qdrant` to enable it.
EASYRAG_STORAGE_BACKEND=
EASYRAG_POSTGRES_DSN=postgresql://user:password@localhost:5432/easyrag
EASYRAG_QDRANT_URL=https://your-qdrant-host:6333
EASYRAG_QDRANT_API_KEY=
EASYRAG_QDRANT_COLLECTION_PREFIX=easyrag
